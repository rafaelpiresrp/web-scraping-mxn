# ── Parâmetros de consulta ────────────────────────────────────────────────
PRECIOS_POR = 2  # 1: Presentación comercial | 2: Kilogramo calculado

STR_FECHA_INICIO = "01/03/2025"
STR_FECHA_FINAL = "15/06/2025"

DT_FECHA_INICIO = datetime.strptime(STR_FECHA_INICIO, "%d/%m/%Y")
DT_FECHA_FINAL = datetime.strptime(STR_FECHA_FINAL, "%d/%m/%Y")

MAX_INTERVALO_ANIOS = 5

# ── URLs do SNIIM ─────────────────────────────────────────────────────────
MAPA_PRECIOS_URL = "http://www.economia-sniim.gob.mx/mapa.asp"
BASE_URL = "http://www.economia-sniim.gob.mx/Nuevo/Consultas/MercadosNacionales/PreciosDeMercado/Agricolas"
ENDPOINT = "/ResultadosConsultaFechaFrutasYHortalizas.aspx"

# ── Execução principal ────────────────────────────────────────────────────
if __name__ == "__main__":
    with urllib.request.urlopen(MAPA_PRECIOS_URL) as response, \
         open(os.path.join(PATH, "mapa.aspx"), "wb") as out_file:

        data = response.read()
        out_file.write(data)
        soup_directorio = BeautifulSoup(data, "html.parser")

        for anchor in soup_directorio.findAll("a", string=re.compile(r"Precio\sde\s(?!la|los|Granos)\w+")):
            producto_id = re.search(r"ProductoId=(\d+)", anchor["href"]).group(1)
            nombre_producto = anchor.string.replace("Precio de ", "").replace("/", "_")

            if not any(p in nombre_producto for p in LISTA_PRODUCTOS):
                continue

            diff_years = DT_FECHA_FINAL.year - DT_FECHA_INICIO.year

            if diff_years > MAX_INTERVALO_ANIOS:
                for anio_inicio in range(DT_FECHA_INICIO.year, DT_FECHA_FINAL.year, MAX_INTERVALO_ANIOS):
                    anio_final = min(anio_inicio + MAX_INTERVALO_ANIOS - 1, DT_FECHA_FINAL.year)
                    url = (
                        f"{BASE_URL}{ENDPOINT}"
                        f"?ProductoId={producto_id}"
                        f"&fechaInicio=01/01/{anio_inicio}"
                        f"&fechaFinal=31/12/{anio_final}"
                        f"&PreciosPorId={PRECIOS_POR}"
                        f"&RegistrosPorPagina="
                    )
                    archivo = f"{nombre_producto.replace(' ', '_')}_{anio_inicio}-{anio_final}"
                    crea_tabla(url, archivo, 1000, nombre_producto.replace(" ", "_"))
            else:
                url = (
                    f"{BASE_URL}{ENDPOINT}"
                    f"?ProductoId={producto_id}"
                    f"&fechaInicio={STR_FECHA_INICIO}"
                    f"&fechaFinal={STR_FECHA_FINAL}"
                    f"&PreciosPorId={PRECIOS_POR}"
                    f"&RegistrosPorPagina="
                )
                archivo = f"{nombre_producto.replace(' ', '_')}_{DT_FECHA_INICIO.year}-{DT_FECHA_FINAL.year}"
                crea_tabla(url, archivo, 1000, nombre_producto.replace(" ", "_"))

    print("\n✔ Descarga finalizada.")

