"""
Scraping de preços agrícolas do SNIIM (México)
Fonte: http://www.economia-sniim.gob.mx
"""

import re
import csv
import os
from datetime import datetime
from urllib.error import HTTPError

import urllib.request
from bs4 import BeautifulSoup

# ── Configuração de caminhos ──────────────────────────────────────────────
PATH = "C:/Users/rafoliveira/Downloads/scraping-mxn/"
TEMP_DIR = os.path.join(PATH, "temp/")
RAW_DIR = os.path.join(PATH, "raw_data/")

os.makedirs(TEMP_DIR, exist_ok=True)
os.makedirs(RAW_DIR, exist_ok=True)

# ── Função de scraping ────────────────────────────────────────────────────
def crea_tabla(url, archivo_salida, paginacion, categoria):
    """Faz scraping da tabela de resultados do SNIIM e salva em CSV."""
    print(f"[{categoria}] URL: {url}{paginacion}")
    try:
        with (
            urllib.request.urlopen(url + str(paginacion), timeout=500) as response,
            open(os.path.join(TEMP_DIR, archivo_salida), "wb") as out_file,
            open(os.path.join(RAW_DIR, archivo_salida + ".csv"), "w", newline="\n", encoding="utf-8") as csvfile,
        ):
            data = response.read()
            soup = BeautifulSoup(data, "html.parser")

            span_paginacion = soup.find("span", attrs={"id": "lblPaginacion"})
            if span_paginacion is None:
                print(f"  → Sem tabela: {archivo_salida}")
                csvfile.close()
                out_file.close()
                os.remove(os.path.join(RAW_DIR, archivo_salida + ".csv"))
                os.remove(os.path.join(TEMP_DIR, archivo_salida))
                return

            paginas = span_paginacion.get_text()
            total_paginas = paginas.split()[-1]
            print(f"  → Páginas: {paginas}")

            if total_paginas != "1":
                return crea_tabla(url, archivo_salida, paginacion * int(total_paginas), categoria)

            out_file.write(data)
            table = soup.find("table", attrs={"id": "tblResultados"})
            if table is None:
                print(f"  → Tabela 'tblResultados' não encontrada: {archivo_salida}")
                return

            writer = csv.writer(csvfile, delimiter=",", quotechar='"', quoting=csv.QUOTE_MINIMAL)
            for row in table.find_all("tr"):
                cells = [td.get_text() for td in row.find_all("td")]
                if cells:
                    writer.writerow(cells)

    except (HTTPError, Exception) as e:
        print(f"  ✗ Erro: {e}")


# ── Lista de produtos ─────────────────────────────────────────────────────
LISTA_PRODUCTOS = [
    "Aguacate", #"Calabacita", "Cebolla", "Cilantro", "Epazote", "Perejil",
    #"Chayote", "Chile Anaheim", "Chile California", "Chile Bola", "Chile Caloro",
